[terra-nvidia]
name=Terra $releasever (NVIDIA)
baseurl=https://repos.fyralabs.com/terra$releasever-nvidia
#metalink=https://tetsudou.fyralabs.com/metalink?repo=terra$releasever-nvidia&arch=$basearch
metadata_expire=6h
type=rpm
gpgcheck=0
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-terra$releasever-nvidia
repo_gpgcheck=0
enabled=0
priority=90
enabled_metadata=1
countme=1
priority=80

[terra-nvidia-source]
name=Terra $releasever (NVIDIA) - Source
baseurl=https://repos.fyralabs.com/terra$releasever-nvidia-source
#metalink=https://tetsudou.fyralabs.com/metalink?repo=terra$releasever-nvidia-source&arch=$basearch
metadata_expire=6h
type=rpm
gpgcheck=0
gpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-terra$releasever-nvidia-source
repo_gpgcheck=0
enabled=0
priority=90
enabled_metadata=0
priority=80
