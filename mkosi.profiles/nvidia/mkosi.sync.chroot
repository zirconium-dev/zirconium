#!/usr/bin/env bash

set -xeuo pipefail

mkdir -p "${SRCDIR}/cache"
pushd "${SRCDIR}/cache"
dnf download dkms-nvidia --repo=terra-nvidia "--arch=$(arch)" "--destdir=${SRCDIR}/cache"
popd

# FIXME: remove once nvidia-open builds on 6.19 ootb https://github.com/NVIDIA/open-gpu-kernel-modules/issues/1021#issuecomment-3875691676
curl -fsSLo "$SRCDIR/cache/cachy.patch" https://raw.githubusercontent.com/CachyOS/CachyOS-PKGBUILDS/refs/heads/master/nvidia/nvidia-utils/kernel-6.19.patch
