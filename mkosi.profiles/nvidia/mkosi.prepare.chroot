#!/usr/bin/env bash

set -xeuo pipefail

mkdir -p "${SRCDIR}/cache"
pushd "${SRCDIR}/cache"
dnf config-manager addrepo --from-repofile=https://negativo17.org/repos/fedora-nvidia.repo
dnf download dkms-nvidia --repo=fedora-nvidia "--arch=noarch" "--destdir=${SRCDIR}/cache"
find . -iname "dkms-nvidia*.rpm"
popd
