#!/usr/bin/env bash

set -xeuo pipefail

# we need this to get modules apparently
cp -r "${BUILDROOT}/var/lib/selinux/targeted/active" "${BUILDROOT}/etc/selinux/targeted/"
cp -r "${BUILDROOT}/var/lib/selinux/final" "${BUILDROOT}/etc/selinux/"

stat "${BUILDROOT}/etc/selinux/targeted/active/modules"
stat "${BUILDROOT}/etc/selinux/targeted/active/booleans.local"
stat "${BUILDROOT}/etc/selinux/targeted/active/file_contexts"
stat "${BUILDROOT}/etc/selinux/targeted/active/file_contexts.homedirs"
stat "${BUILDROOT}/etc/selinux/targeted/active/modules/100/bootupd/cil"
stat "${BUILDROOT}/etc/selinux/targeted/active/modules/100/bootupd/hll"
stat "${BUILDROOT}/etc/selinux/targeted/active/modules/100/bootupd/lang_ext"
